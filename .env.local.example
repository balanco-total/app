NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public app URL (used in payment redirect URLs; defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=https://seudominio.com

# Pluggy — Open Finance (bank account sync)
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_WEBHOOK_SECRET=

# SMTP — botão de suporte (e-mails para suporte@balancototal.com.br)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="BalançoTotal <suporte@balancototal.com.br>"
SUPPORT_EMAIL=suporte@balancototal.com.br

# Cron — proteção da rota /api/cron/due-today (Vercel Cron envia este header automaticamente)
CRON_SECRET=
